# OpenRouter (default — access to 200+ models with one key)
LLM_MODEL=openrouter/anthropic/claude-sonnet-4-6
OPEN_ROUTER_API_KEY=sk-or-...
OPEN_ROUTER_BASE_URL=https://openrouter.ai/api/v1


# Per-agent model overrides (all fall back to LLM_MODEL if not set)
PLANNER_MODEL=openrouter/google/gemini-2.0-flash-001
HYPOTHESIS_MODEL=openrouter/google/gemini-2.0-flash-001
EXECUTOR_MODEL=openrouter/anthropic/claude-sonnet-4-6
CRITIC_MODEL=openrouter/anthropic/claude-sonnet-4-6
SYNTHESIZER_MODEL=openrouter/anthropic/claude-sonnet-4-6
EDA_AGENT_MODEL=openrouter/anthropic/claude-sonnet-4-6
UNI_NG_MODEL=openrouter/google/gemini-2.0-flash-001
UNI_G_MODEL=openrouter/google/gemini-2.0-flash-001
MULTI_NG_MODEL=openrouter/google/gemini-2.0-flash-001
MULTI_G_MODEL=openrouter/google/gemini-2.0-flash-001
